#!/usr/bin/env python3
"""Executable acceptance criteria — template.

Copy to .claude/spec_check.py, adapt the checks to the task's spec
(.claude/specs/<task-slug>.md), and wire it into .claude/aep-check.sh:

    #!/bin/sh
    make test && python3 .claude/spec_check.py

Rules of thumb:
- Prefer BEHAVIORAL checks (run the artifact, assert observable behavior)
  over keyword greps: greps false-fail on renamed concepts and false-pass
  on keyword stuffing.
- One check per spec criterion, same numbering as the spec's Acceptance list.
- Exit 0 only when every criterion passes — the verify gate runs this, so a
  red criterion blocks "done".
"""
import subprocess
import sys

FAILS = []


def chk(name, ok):
    print(("PASS " if ok else "FAIL ") + name)
    if not ok:
        FAILS.append(name)


def probe(*cmd, timeout=30):
    """Behavioral helper: run a command, return (exit_code, combined_output)."""
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
    return r.returncode, r.stdout + r.stderr


# --- criteria: mirror the spec's Acceptance numbering --------------------
# Behavioral example (CLI): the command runs and produces the contract output
#   code, out = probe(sys.executable, "todo.py", "add", "example")
#   chk("C1 add exits 0 and prints a numeric id", code == 0 and out.strip().isdigit())
#
# Behavioral example (API): boot the server on a free port, hit the endpoint,
# assert status codes — see the AEP docs for a full harness pattern.
#
# Static example — only where behavior is impractical to probe:
#   src = open("index.html", encoding="utf-8").read()
#   chk("C2 zero external resources", "https://" not in src)

chk("C0 replace the example criteria with the task's real Acceptance list", False)

# -------------------------------------------------------------------------
if FAILS:
    print(f"{len(FAILS)} criteria failing")
    sys.exit(1)
print("all criteria pass")
